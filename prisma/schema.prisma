// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [postgis]
}

enum UserRole {
  APPRAISER
  SUPERVISOR
  ADMIN
}

enum PropertyType {
  HOUSE
  APARTMENT
  COMMERCIAL
  LAND
  INDUSTRIAL
}

enum PropertyStatus {
  DRAFT
  IN_PROGRESS
  PENDING_REVIEW
  COMPLETED
  ARCHIVED
}

enum ConservationState {
  EXCELLENT
  GOOD
  REGULAR
  POOR
  VERY_POOR
}

enum ReportStatus {
  GENERATING
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum RoadType {
  ASPHALT
  CONCRETE
  PAVING_STONES
  DIRT
  GRAVEL
}

enum UrbanConsolidation {
  CONSOLIDATED
  IN_CONSOLIDATION
  INCIPIENT
  RURAL
}

enum LandUseType {
  RESIDENTIAL
  COMMERCIAL
  MIXED_USE
  INDUSTRIAL
  AGRICULTURAL
  INSTITUTIONAL
}

enum PopulationDensity {
  HIGH
  MEDIUM
  LOW
  VERY_LOW
}

enum FoundationType {
  ISOLATED_FOOTINGS
  CONTINUOUS_FOOTINGS
  SLAB_ON_GRADE
  PILES
  DEEP_FOUNDATION
  NONE
}

enum StructureType {
  REINFORCED_CONCRETE
  STEEL
  WOOD
  MASONRY
  MIXED
  NONE
}

enum MasonryType {
  BRICK
  CONCRETE_BLOCK
  ADOBE
  BAHAREQUE
  PREFABRICATED_PANELS
  NONE
}

enum FloorType {
  REINFORCED_CONCRETE_SLAB
  STEEL_BEAMS
  WOOD_JOISTS
  NONE
}

enum CoatingType {
  CERAMIC
  PORCELAIN
  NATURAL_STONE
  PAINT
  PLASTER
  STUCCO
  WALLPAPER
  WOOD_PANELING
  NONE
}

enum CarpentryType {
  WOOD
  ALUMINUM
  PVC
  METAL
  NONE
}

enum GlazingType {
  CLEAR_GLASS
  TEMPERED_GLASS
  LAMINATED_GLASS
  DOUBLE_GLAZED
  NONE
}

enum PlumbingType {
  PVC
  COPPER
  GALVANIZED_STEEL
  PEX
  NONE
}

enum ElectricalType {
  CONDUIT
  ARMORED_CABLE
  NON_METALLIC_CABLE
  EXPOSED
  NONE
}

enum RiskLevel {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ValuationPurpose {
  MORTGAGE_LOAN
  PURCHASE_SALE
  INSURANCE
  LEGAL_LITIGATION
  INHERITANCE
  ASSET_VALUATION
  OTHER
}

enum PropertyRegime {
  PRIVATE
  PUBLIC
  COMMUNAL
  HORIZONTAL_PROPERTY
}

enum SocioeconomicLevel {
  HIGH
  MEDIUM_HIGH
  MEDIUM
  MEDIUM_LOW
  LOW
}

enum ValuationObject {
  MARKET_VALUE
  LIQUIDATION_VALUE
  RESCUE_VALUE
  SCRAP_VALUE
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(APPRAISER)
  createdAt DateTime @default(now())

  properties       Property[]
  valuationReports ValuationReport[]
  auditLogs        AuditLog[]
}

model ValuationRequest {
  id                    Int      @id @default(autoincrement())

  // Requesting Entity
  financialInstitution  String?  // Nombre de la entidad financiera
  branchOffice          String?  // Oficina/sucursal
  creditOfficer         String?  // Oficial de crédito responsable

  // Client Information
  clientName            String?  // Cliente solicitante
  clientId              String?  // Cédula/RUC del cliente
  clientPhone           String?
  clientEmail           String?

  // Legal Owner (may differ from client)
  legalOwnerName        String?  // Propietario legal según escrituras
  legalOwnerId          String?  // Cédula/RUC del propietario

  // Purpose
  purpose               ValuationPurpose
  purposeDescription    String?  @db.Text // Descripción adicional si es necesario
  valuationObject       String?

  // Loan Information (if applicable)
  requestedLoanAmount   Float?
  loanTerm              Int?     // months

  // Request Metadata
  requestDate           DateTime @default(now())
  requiredDate          DateTime? // Fecha límite de entrega

  // Relations
  propertyId            Int      @unique
  property              Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Property {
  id          Int            @id @default(autoincrement())
  userId      Int
  user        User           @relation(fields: [userId], references: [id])

  // Basic Information
  address     String
  city        String
  state       String
  zipCode     String?
  parish      String?        // 👈 NUEVO: Parroquia
  neighborhood String?       // 👈 NUEVO: Barrio/Sector
  type        PropertyType
  status      PropertyStatus @default(DRAFT)

  // Geospatial Data (PostGIS)
  latitude    Float
  longitude   Float

  // ========== LINDEROS EXACTOS ==========
  northBoundaryLength     Float?   // metros
  northBoundaryAdjacent   String?  // con qué colinda
  southBoundaryLength     Float?
  southBoundaryAdjacent   String?
  eastBoundaryLength      Float?
  eastBoundaryAdjacent    String?
  westBoundaryLength      Float?
  westBoundaryAdjacent    String?

  // ========== ÁREAS ==========
  landArea                Float?   // m² (general)
  builtArea               Float?   // m² (general)
  areaAccordingToDeed     Float?   // m² según escritura
  areaOnSite              Float?   // m² medida en sitio

  // Physical Characteristics
  bedrooms          Int?
  bathrooms         Int?
  floors            Int?
  yearBuilt         Int?
  frontageWidth     Float?
  topography        String?
  occupancyStatus   String?
  zoning            String?
  parking           Int?
  amenities         String[]
  roomDistribution  String?  @db.Text // 👈 NUEVO: Distribución de ambientes
  sectorAppreciation String?          // 👈 NUEVO: Plusvalía (Alta, Media, Baja, Nula)

  // ========== ENTORNO Y SERVICIOS PÚBLICOS ==========
  zoneClassification      LandUseType?
  urbanConsolidation      UrbanConsolidation?
  populationDensity       PopulationDensity?
  roadType                RoadType?
  roadCondition           String?
  sidewalkAvailable       Boolean  @default(false)
  hasPotableWater         Boolean  @default(false)
  hasStormDrainage        Boolean  @default(false)
  hasSanitarySewer        Boolean  @default(false)
  hasElectricityAerial    Boolean  @default(false)
  hasElectricityUnderground Boolean @default(false)
  hasTelephone            Boolean  @default(false)
  hasInternet             Boolean  @default(false)
  hasStreetLighting       Boolean  @default(false)
  hasGarbageCollection    Boolean  @default(false)

  // ========== ESPECIFICACIONES TÉCNICAS GRANULARES ==========
  foundationType          FoundationType?
  foundationDescription   String?
  structureType           StructureType?
  structureDescription    String?
  masonryType             MasonryType?
  masonryDescription      String?
  floorType               FloorType?
  floorDescription        String?
  exteriorCoating         CoatingType?
  interiorCoating         CoatingType?
  coatingDescription      String?
  carpentryType           CarpentryType?
  carpentryDescription    String?
  locksmithType           String?
  locksmithDescription    String?
  glazingType             GlazingType?
  glazingDescription      String?
  plumbingType            PlumbingType?
  plumbingDescription     String?
  electricalType          ElectricalType?
  electricalDescription   String?
  electricalCapacity      String?

  // Construction Details
  roofMaterial       String?
  wallMaterial       String?
  floorMaterial      String?
  conservationState  ConservationState?

  // Legal Information
  legalOwner         String?
  cadastralNumber    String?
  registrationNumber String?
  hasLiens           Boolean @default(false)
  hasEncumbrances    Boolean @default(false)

  // ========== SBS COMPLIANCE FIELDS ==========
  propertyRegime              PropertyRegime?
  inspectionDate              DateTime?
  personPresentAtInspection   String?
  saturationIndex             Float?
  socioeconomicLevel          SocioeconomicLevel?
  cos                         Float?
  cus                         Float?
  easementsAndRestrictions    String?  @db.Text
  panoramicCharacteristics    String?  @db.Text
  rentableUnits               Int?
  aliquotPercentage           Float?
  roofCondition               String?
  fenceCondition              String?
  ceilingCondition            String?
  stairsCondition             String?
  numberOfFacades             Int?
  hasMaintenanceLogs          Boolean  @default(false)
  maintenanceNotes            String?  @db.Text

  // Metadata
  createdAt   DateTime @default(now())
  completedAt DateTime?
  updatedAt   DateTime @default(now()) @updatedAt

  // Relations
  valuationRequest    ValuationRequest?
  photos              PropertyPhoto[]
  comparables         Comparable[]
  valuationReports    ValuationReport[]
  riskAssessments     RiskAssessment[]
  additionalWorks     AdditionalWork[]
  constructionBlocks  ConstructionBlock[] // 👈 NUEVO: Relación a bloques de construcción
  auditLogs           AuditLog[]
}

// 👈 NUEVO MODELO: BLOQUES DE CONSTRUCCIÓN
model ConstructionBlock {
  id                  Int               @id @default(autoincrement())
  propertyId          Int
  property            Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  name                String            // Ej: "Bloque 1 (Casa)", "Bloque 2 (Mediagua)"
  area                Float             // Área en m²
  yearBuilt           Int               // Año de construcción
  conservationState   ConservationState // Estado de conservación (EXCELLENT, GOOD, REGULAR, POOR, VERY_POOR)

  replacementCostPerM2 Float?           // CRN ($/m²) sugerido por el perito

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model PropertyPhoto {
  id         Int      @id @default(autoincrement())
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  minioKey   String
  url        String
  category   String
  caption    String?

  latitude   Float?
  longitude  Float?
  timestamp  DateTime?
  deviceInfo String?

  detectedIssues String[]
  aiConfidence   Float?

  createdAt  DateTime @default(now())
}

model Comparable {
  id         Int      @id @default(autoincrement())
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  source     String
  sourceUrl  String?
  address    String
  distance   Float

  price      Float
  pricePerM2 Float
  area       Float
  bedrooms   Int?
  bathrooms  Int?
  yearBuilt  Int?

  locationAdjustment Float @default(1.0)
  sizeAdjustment     Float @default(1.0)
  ageAdjustment      Float @default(1.0)
  qualityAdjustment  Float @default(1.0)

  adjustedPrice      Float

  listingDate DateTime?
  createdAt   DateTime  @default(now())
}

model ValuationReport {
  id         Int          @id @default(autoincrement())
  propertyId Int
  property   Property     @relation(fields: [propertyId], references: [id])
  userId     Int
  user       User         @relation(fields: [userId], references: [id])

  status     ReportStatus @default(GENERATING)

  valuationObject  ValuationObject?

  marketValue          Float?
  costValue            Float?
  incomeValue          Float?
  cadastralValue       Float?
  realizationValue     Float?
  finalValue           Float?

  landValue            Float?
  constructionCost     Float?
  additionalWorksCost  Float?
  depreciationAmount   Float?
  depreciationMethod   String?

  totalUsefulLife      Int?
  remainingUsefulLife  Int?
  chronologicalAge     Int?

  estimatedMonthlyRent Float?
  annualGrossIncome    Float?
  operatingExpenses    Float?
  annualNetIncome      Float?
  capitalizationRate   Float?

  parametersSnapshot   Json?

  environmentDescription String?  @db.Text
  technicalDescription   String? @db.Text
  valueJustification     String?  @db.Text

  pdfUrl               String?
  documentHash         String?

  generatedAt  DateTime?
  approvedAt   DateTime?
  approvedBy   Int?
  rejectedAt   DateTime?
  rejectionReason   String?  @db.Text

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  auditLogs    AuditLog[]
}

model RiskAssessment {
  id         Int      @id @default(autoincrement())
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  floodRisk       RiskLevel @default(NONE)
  seismicRisk     RiskLevel @default(NONE)
  landslideRisk   RiskLevel @default(NONE)
  volcanicRisk    RiskLevel @default(NONE)
  tsunamiRisk     RiskLevel @default(NONE)

  hasPastIndustrialActivity       Boolean @default(false)
  pastIndustrialActivityDetails   String? @db.Text
  hasUndergroundTanks             Boolean @default(false)
  undergroundTanksDetails         String?
  hasAsbestos                     Boolean @default(false)
  asbestosLocation                String?
  hasSoilContamination            Boolean @default(false)
  soilContaminationDetails        String? @db.Text
  nearProtectedArea               Boolean @default(false)
  protectedAreaName               String?
  distanceToProtectedArea         Float?
  nearHighRiskZone                Boolean @default(false)
  highRiskZoneType                String?
  distanceToHighRiskZone          Float?
  hasOtherEnvironmentalRisks      Boolean @default(false)
  otherEnvironmentalRisksDetails  String? @db.Text

  hasStructuralCracks             Boolean @default(false)
  hasSettlement                   Boolean @default(false)
  hasHumidity                     Boolean @default(false)
  hasCorrosion                    Boolean @default(false)
  hasFoundationIssues             Boolean @default(false)
  hasRoofDamage                   Boolean @default(false)

  detectedIssues                  String[]

  overallRisk                     RiskLevel @default(NONE)
  riskNotes                       String?   @db.Text

  nearbyPOIs      String[]
  accessQuality   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdditionalWork {
  id                    Int      @id @default(autoincrement())
  propertyId            Int
  property              Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  name                  String
  description           String?  @db.Text
  category              String

  area                  Float?
  yearBuilt             Int?

  replacementCost       Float
  depreciationPercent   Float    @default(0)
  depreciatedValue      Float

  conservationState     ConservationState?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AuditLog {
  id         Int      @id @default(autoincrement())

  userId     Int?
  user       User?    @relation(fields: [userId], references: [id])

  action     String
  entity     String
  entityId   Int

  changes    String?  @db.Text
  metadata   String?  @db.Text

  timestamp  DateTime @default(now())

  propertyId Int?
  property   Property? @relation(fields: [propertyId], references: [id])

  reportId   Int?
  report     ValuationReport? @relation(fields: [reportId], references: [id])
}
