apiVersion: v1
kind: Secret
metadata:
  name: tasacionec-secrets
  labels:
    app: tasacionec
type: Opaque
stringData:
  # Database password
  postgres-password: "CHANGE_ME"
  database-url: "postgresql://postgres:CHANGE_ME@postgres:5432/app"
  
  # JWT secret for authentication
  jwt-secret: "CHANGE_ME_LONG_RANDOM_STRING"
  
  # Admin password
  admin-password: "CHANGE_ME"
  
  # MinIO credentials
  minio-password: "CHANGE_ME"
  
  # OpenAI API key
  openai-api-key: "sk-..."
  
  # OpenRouter API key (optional)
  openrouter-api-key: "sk-or-v1-..."

---
# Instructions for creating secrets:
# 1. Copy this file to secrets.yaml (don't commit secrets.yaml!)
# 2. Replace all CHANGE_ME values with secure random strings
# 3. Apply with: kubectl apply -f secrets.yaml
# 
# To generate secure random strings:
# openssl rand -base64 32
